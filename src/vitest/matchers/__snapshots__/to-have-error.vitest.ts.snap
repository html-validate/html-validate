exports[`toHaveError() > should handle passing object as expected error 1`] = `
"expect(received).toHaveError(expected)

Expected error to equal:
  Array [
  ObjectContaining {
    "line": 3,
    "ruleId": "asdf",
    "size": 12,
  },
]
Received:
  Array [
  Object {
    "column": 8,
    "context": Object {
      "foo": "bar",
    },
    "line": 4,
    "message": "mock message",
    "offset": 37,
    "ruleId": "my-rule",
    "selector": "#foo > div",
    "severity": 2,
    "size": 11,
  },
]

Difference:

- Expected
+ Received

  [
-   ObjectContaining {
-     "line": 3,
-     "ruleId": "asdf",
-     "size": 12,
+   {
+     "column": 8,
+     "context": {
+       "foo": "bar",
+     },
+     "line": 4,
+     "message": "mock message",
+     "offset": 37,
+     "ruleId": "my-rule",
+     "selector": "#foo > div",
+     "severity": 2,
+     "size": 11,
    },
  ]"
`;
